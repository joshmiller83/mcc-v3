{#
  MCC Photo Placeholder SDC Template
#}
<div{{ attributes.addClass('mcc-photo-placeholder') }}>
  <div class="mcc-photo-placeholder__inner">
    <svg class="mcc-photo-placeholder__icon" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
      <circle cx="9" cy="9" r="2"/>
      <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
    </svg>
    <span class="mcc-photo-placeholder__text">{{ label|default('Drop a photo or browse files') }}</span>
  </div>
</div>
